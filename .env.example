# @required
# @type url
# @description API base URL for the service
API_URL=

# @required
# @description Database connection string
DATABASE_URL=

# @type number
# @description Port number to listen on
PORT=3000

# @type bool
# @description Enable debug logging
DEBUG=false

# @type email
# @description Admin contact email
ADMIN_EMAIL=

# @type uuid
# @description Unique application identifier
APP_ID=

# @type json
# @description JSON config blob
APP_CONFIG=

# @required
# @pattern ^[A-Z]{2,5}$
# @description ISO country code (uppercase letters only)
COUNTRY_CODE=

# Optional feature flag
FEATURE_FLAG_NEW_UI=
